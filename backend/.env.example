GOOGLE_API_KEY=AIza-your-key-here
GOOGLE_CHAT_MODEL=gemini-2.5-flash
GOOGLE_EMBED_MODEL=gemini-embedding-001
# AI provider: "local" = offline (không cần key), "gemini" = gọi Google API.
EMBED_PROVIDER=local
LLM_PROVIDER=local
CHROMA_DIR=./data/chroma
# --- Cơ sở dữ liệu ---
# Mặc định SQLite (chạy ngay, không cần cài đặt gì):
DATABASE_URL=sqlite:///./data/app.db
# SQL Server (cần ODBC Driver 17 + pyodbc) — ví dụ instance tên THANH, user sa:
# DATABASE_URL=mssql+pyodbc://sa:123@localhost\THANH/maple?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes
# Default instance thì bỏ \THANH: ...@localhost/maple?driver=...
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=720
# Thêm http://localhost,https://localhost,capacitor://localhost cho app Capacitor.
CORS_ORIGINS=http://localhost:5173,http://localhost,https://localhost,capacitor://localhost
