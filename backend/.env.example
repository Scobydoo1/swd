GOOGLE_API_KEY=AIza-your-key-here
GOOGLE_CHAT_MODEL=gemini-2.5-flash
GOOGLE_EMBED_MODEL=gemini-embedding-001
# AI provider: "local" = offline (không cần key), "gemini" = gọi Google API.
EMBED_PROVIDER=local
LLM_PROVIDER=local
CHROMA_DIR=./data/chroma
# --- Cơ sở dữ liệu ---
# Mặc định SQLite (chạy ngay, không cần cài đặt gì):
DATABASE_URL=sqlite:///./data/app.db
# SQL Server (cần ODBC Driver 17 + pyodbc) — thay <user>/<password>/<INSTANCE>;
# nên tạo login riêng cho app thay vì dùng sa:
# DATABASE_URL=mssql+pyodbc://<user>:<password>@localhost\<INSTANCE>/maple?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes
# Default instance thì bỏ \<INSTANCE>: ...@localhost/maple?driver=...
# BẮT BUỘC đổi thành chuỗi ngẫu nhiên dài, ví dụ tạo bằng:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=720
# http://localhost,https://localhost,capacitor://localhost cho app Capacitor.
# https://scobydoo1.github.io là origin của frontend host trên GitHub Pages.
CORS_ORIGINS=http://localhost:5173,http://localhost,https://localhost,capacitor://localhost,https://scobydoo1.github.io

# --- Google OAuth login ---
GOOGLE_OAUTH_CLIENT_ID=

# --- Gửi email cấp tài khoản ---
# Production (Render chặn SMTP): dùng Brevo API — đăng ký free tại brevo.com,
# verify sender email, lấy API key (SMTP & API -> API Keys).
BREVO_API_KEY=
# Local: Gmail SMTP (App Password: https://myaccount.google.com/apppasswords)
SMTP_USER=
SMTP_PASSWORD=
# Sender hiển thị; với Brevo PHẢI là email đã verify. Trống -> dùng SMTP_USER.
MAIL_FROM=
APP_LOGIN_URL=http://localhost:5173

# --- Admin đầu tiên (tự tạo khi startup nếu DB chưa có admin) ---
# Đặt email thật của bạn + mật khẩu MẠNH (đừng dùng mật khẩu demo nào trong repo);
# trên production hãy đổi mật khẩu ngay sau lần đăng nhập đầu.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=<mat-khau-manh-cua-ban>
ADMIN_FULL_NAME=Quản trị viên

# --- Vector backend: chroma (local) | pgvector (Neon Postgres) ---
VECTOR_BACKEND=chroma
